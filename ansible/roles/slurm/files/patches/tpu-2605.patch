+
+AM_CPPFLAGS = -I$(top_srcdir) -I$(top_builddir)
+
+pkglib_LTLIBRARIES = cli_filter_tpu.la
+
+cli_filter_tpu_la_SOURCES = cli_filter_tpu.c
+cli_filter_tpu_la_LDFLAGS = $(SO_LDFLAGS) $(PLUGIN_FLAGS)
